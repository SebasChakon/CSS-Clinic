<div class="min-h-screen bg-gray-100 flex flex-col items-center justify-center py-10">
  <div class="bg-white shadow-lg rounded-xl w-full max-w-md p-8">
    <h2 class="text-2xl font-semibold text-blue-600 mb-6 text-center">Iniciar sesión</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name),
                 html: { class: "space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, "Correo", class: "block text-gray-700 font-medium mb-1" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
                          class: "w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-400" %>
      </div>

      <div>
        <%= f.label :password, "Contraseña", class: "block text-gray-700 font-medium mb-1" %>
        <%= f.password_field :password, autocomplete: "current-password",
                             class: "w-full p-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-blue-400" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "mr-2" %>
          <%= f.label :remember_me, "Recordarme", class: "text-gray-700" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Entrar",
                     class: "w-full bg-blue-600 text-white py-2 rounded-md hover:bg-blue-700 transition" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>