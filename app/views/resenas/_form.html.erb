<%= form_with model: [ @reserva, @resena ], local: true do |f| %>
  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700">Calificación</label>
    <div class="flex items-center space-x-2 mt-2">
      <% (1..5).to_a.reverse.each do |n| %>
        <label class="flex items-center cursor-pointer">
          <%= f.radio_button :rating, n, id: "star_#{n}" %>
          <svg class="w-5 h-5 ml-1" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.163c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118L10 13.347l-3.37 2.448c-.784.57-1.839-.196-1.54-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.643 9.384c-.783-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69L9.049 2.927z"/>
          </svg>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :comment, "Comentario (opcional)", class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :comment, rows: 4, class: "w-full rounded border p-2", placeholder: "Cuenta tu experiencia..." %>
  </div>

  <div class="flex gap-2">
    <%= f.submit (@resena.new_record? ? "Publicar reseña" : "Actualizar reseña"), class: "bg-green-600 text-white px-4 py-2 rounded" %>
    <%= link_to 'Cancelar', reserva_path(@reserva), class: 'bg-gray-200 px-4 py-2 rounded' %>
  </div>
<% end %>
