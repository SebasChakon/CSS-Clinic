<%= form_with model: [ @reserva, @resena ], local: true do |f| %>
  <div class="mb-4">
    <label class="block text-sm font-medium text-gray-700 mb-3">Calificación</label>
    <div class="space-y-2">
      <% (1..5).reverse_each do |n| %>
        <label class="flex items-center cursor-pointer hover:bg-gray-50 p-2 rounded">
          <%= f.radio_button :rating, n, class: "mr-3 w-4 h-4" %>
          <span class="flex items-center">
            <% n.times do %>
              <svg class="w-5 h-5 text-yellow-400" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.957a1 1 0 00.95.69h4.163c.969 0 1.371 1.24.588 1.81l-3.37 2.448a1 1 0 00-.364 1.118l1.287 3.957c.3.922-.755 1.688-1.54 1.118L10 13.347l-3.37 2.448c-.784.57-1.839-.196-1.54-1.118l1.287-3.957a1 1 0 00-.364-1.118L2.643 9.384c-.783-.57-.38-1.81.588-1.81h4.163a1 1 0 00.95-.69L9.049 2.927z"/>
              </svg>
            <% end %>
            <span class="ml-2 text-gray-700">(<%= n %> <%= n == 1 ? 'estrella' : 'estrellas' %>)</span>
          </span>
        </label>
      <% end %>
    </div>
  </div>

  <div class="mb-4">
    <%= f.label :comment, "Comentario (opcional)", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :comment, rows: 4, class: "w-full rounded-md border border-gray-300 p-3 focus:ring-2 focus:ring-blue-400 focus:border-transparent", placeholder: "Cuenta tu experiencia..." %>
  </div>

  <div class="flex gap-2">
    <%= f.submit (@resena.new_record? ? "Publicar reseña" : "Actualizar reseña"), class: "bg-green-600 text-white px-6 py-2 rounded-md hover:bg-green-700 transition" %>
    <%= link_to 'Cancelar', reserva_path(@reserva), class: 'bg-gray-200 text-gray-700 px-6 py-2 rounded-md hover:bg-gray-300 transition' %>
  </div>
<% end %>