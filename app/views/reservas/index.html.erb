<div class="container mx-auto px-4 py-8 max-w-6xl">
  <!-- Header -->
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-gray-900">
      <% if current_user.paciente? %>
        Mis Reservas Médicas
      <% else %>
        Mis Citas con Pacientes
      <% end %>
      <span class="text-gray-500 text-lg font-normal ml-2">(<%= @reservas.count %>)</span>
    </h1>
    <div class="flex space-x-3">
      <%= link_to 'Volver al Inicio', root_path, class: 'bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 font-medium' %>
    </div>
  </div>

  <!-- Estadísticas para Médicos -->
  <% if current_user.doctor? && @estadisticas %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
      <div class="bg-white rounded-xl shadow-sm border p-5 text-center">
        <div class="text-2xl font-bold text-blue-600"><%= @estadisticas[:total] %></div>
        <div class="text-sm text-gray-600 mt-1">Total Citas</div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border p-5 text-center">
        <div class="text-2xl font-bold text-yellow-600"><%= @estadisticas[:pendientes] %></div>
        <div class="text-sm text-gray-600 mt-1">Pendientes</div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border p-5 text-center">
        <div class="text-2xl font-bold text-green-600"><%= @estadisticas[:confirmadas] %></div>
        <div class="text-sm text-gray-600 mt-1">Confirmadas</div>
      </div>
      <div class="bg-white rounded-xl shadow-sm border p-5 text-center">
        <div class="text-2xl font-bold text-purple-600"><%= @estadisticas[:proximas] %></div>
        <div class="text-sm text-gray-600 mt-1">Próximas</div>
      </div>
    </div>
  <% end %>

  <!-- Sección de Próxima Cita -->
  <% if @proxima_cita %>
    <div class="bg-white rounded-2xl p-6 mb-8 shadow-lg border border-gray-200">
      <div class="flex justify-between items-start">
        <div class="flex-1">
          <h2 class="text-2xl font-bold mb-6 text-gray-900">Tu Próxima Cita</h2>
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-600 mb-1">
                  <%= current_user.doctor? ? 'PACIENTE:' : 'MÉDICO:' %>
                </label>
                <p class="text-xl font-bold text-gray-900">
                  <%= current_user.doctor? ? @proxima_cita.paciente.nombre_completo : @proxima_cita.doctor.nombre_completo %>
                </p>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-600 mb-1">FECHA Y HORA:</label>
                <p class="text-xl font-bold text-gray-900">
                  <%= l(@proxima_cita.fecha_hora, format: :long) %>
                </p>
              </div>
            </div>
            
            <div class="space-y-4">
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-600 mb-1">DURACIÓN:</label>
                  <p class="font-semibold text-gray-900">
                    <%= @proxima_cita.duracion %> minutos
                  </p>
                </div>
                
                <div>
                  <label class="block text-sm font-medium text-gray-600 mb-1">UBICACIÓN:</label>
                  <p class="font-semibold text-gray-900">
                    <%= @proxima_cita.ubicacion %>
                  </p>
                </div>
              </div>
              
              <div>
                <label class="block text-sm font-medium text-gray-600 mb-1">MOTIVO:</label>
                <p class="font-semibold text-gray-900"><%= truncate(@proxima_cita.motivo, length: 100) %></p>
              </div>

              <div>
                <label class="block text-sm font-medium text-gray-600 mb-1">ESTADO:</label>
                <span class="px-3 py-1 text-sm font-semibold rounded-full <%= estado_badge_class(@proxima_cita.estado) %>">
                  <%= @proxima_cita.estado.humanize %>
                </span>
              </div>
            </div>
          </div>
        </div>
        
        <div class="flex flex-col space-y-3 ml-6">
          <%= link_to 'Ver Detalles', @proxima_cita, class: 'bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 font-medium text-center' %>
          <% if current_user.doctor? %>
            <% if @proxima_cita.pendiente? %>
              <%= link_to 'Confirmar', confirmar_reserva_path(@proxima_cita), 
                  class: 'bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700 font-medium text-center' %>
            <% end %>
            <% if @proxima_cita.confirmada? %>
              <%= link_to 'Completar', completar_reserva_path(@proxima_cita), 
                  class: 'bg-purple-600 text-white px-6 py-3 rounded-lg hover:bg-purple-700 font-medium text-center' %>
            <% end %>
          <% end %>
          <% if @proxima_cita.pendiente? || @proxima_cita.confirmada? %>
            <%= link_to 'Cancelar', cancelar_reserva_path(@proxima_cita), 
                data: { confirm: '¿Estás seguro de cancelar esta cita?' },
                class: 'bg-red-600 text-white px-6 py-3 rounded-lg hover:bg-red-700 font-medium text-center' %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <!-- Filtros -->
  <div class="bg-white rounded-2xl shadow-sm border p-6 mb-8">
    <h3 class="text-lg font-semibold text-gray-800 mb-4">Filtrar Reservas</h3>
    <div class="flex flex-wrap gap-3">
      <%= link_to 'Todas', reservas_path, 
          class: "px-6 py-3 rounded-full text-sm font-medium #{params[:filtro].blank? ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      
      <%= link_to 'Próximas', reservas_path(filtro: 'proximas'), 
          class: "px-6 py-3 rounded-full text-sm font-medium #{params[:filtro] == 'proximas' ? 'bg-green-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      
      <%= link_to 'Pasadas', reservas_path(filtro: 'pasadas'), 
          class: "px-6 py-3 rounded-full text-sm font-medium #{params[:filtro] == 'pasadas' ? 'bg-yellow-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      
      <%= link_to 'Pendientes', reservas_path(filtro: 'pendientes'), 
          class: "px-6 py-3 rounded-full text-sm font-medium #{params[:filtro] == 'pendientes' ? 'bg-orange-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
      
      <%= link_to 'Confirmadas', reservas_path(filtro: 'confirmadas'), 
          class: "px-6 py-3 rounded-full text-sm font-medium #{params[:filtro] == 'confirmadas' ? 'bg-purple-600 text-white' : 'bg-gray-200 text-gray-700 hover:bg-gray-300'}" %>
    </div>
  </div>

  <!-- Lista de Reservas - Estilo Tarjetas -->
  <% if @reservas.any? %>
    <div class="space-y-4">
      <% @reservas.each do |reserva| %>
        <div class="bg-white rounded-2xl shadow-sm border p-6 hover:shadow-md transition-shadow">
          <div class="flex justify-between items-start">
            <div class="flex-1">
              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Columna 1: Médico/Paciente -->
                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-2">
                    <%= current_user.doctor? ? 'PACIENTE' : 'MÉDICO' %>
                  </label>
                  <p class="text-lg font-bold text-gray-900">
                    <%= current_user.doctor? ? reserva.paciente.nombre_completo : reserva.doctor.nombre_completo %>
                  </p>
                  <% if current_user.doctor? && reserva.paciente.phone.present? %>
                    <p class="text-sm text-gray-600 mt-1"><%= reserva.paciente.phone %></p>
                  <% end %>
                </div>

                <!-- Columna 2: Fecha y Hora -->
                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-2">FECHA Y HORA</label>
                  <p class="text-lg font-bold text-gray-900">
                    <%= l(reserva.fecha_hora, format: :long) %>
                  </p>
                  <p class="text-sm text-gray-600 mt-1">[Duración: <%= reserva.duracion %> min]</p>
                </div>

                <!-- Columna 3: Motivo y Estado -->
                <div>
                  <label class="block text-sm font-medium text-gray-500 mb-2">MOTIVO</label>
                  <p class="text-lg font-bold text-gray-900 mb-3">
                    <%= truncate(reserva.motivo, length: 50) %>
                  </p>
                  <span class="px-4 py-2 text-sm font-semibold rounded-full <%= estado_badge_class(reserva.estado) %>">
                    <%= reserva.estado.humanize %>
                  </span>
                </div>
              </div>
            </div>

            <!-- Acciones -->
            <div class="flex flex-col space-y-2 ml-6">
              <%= link_to 'Ver', reserva, class: 'bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 text-sm text-center font-medium' %>
              <% if [reserva.paciente_id, reserva.doctor_id].include?(current_user.id) %>
                <%= link_to "Chat", reserva_mensajes_path(reserva), class: "bg-indigo-600 text-white px-4 py-2 rounded-lg hover:bg-indigo-700 text-sm text-center font-medium" %>
              <% end %>
              
              <% if current_user.doctor? %>
                <% if reserva.pendiente? %>
                  <%= link_to 'Confirmar', confirmar_reserva_path(reserva), 
                      class: 'bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 text-sm text-center font-medium' %>
                <% end %>
                <% if reserva.confirmada? %>
                  <%= link_to 'Completar', completar_reserva_path(reserva), 
                      class: 'bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 text-sm text-center font-medium' %>
                <% end %>
              <% end %>
              
              <% if reserva.pendiente? || reserva.confirmada? %>
                <%= link_to 'Cancelar', cancelar_reserva_path(reserva), 
                    data: { confirm: '¿Estás seguro de cancelar esta reserva?' },
                    class: 'bg-red-600 text-white px-4 py-2 rounded-lg hover:bg-red-700 text-sm text-center font-medium' %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Botón Volver al Final -->
    <div class="flex justify-center mt-8">
      <%= link_to 'Volver al Inicio', root_path, class: 'bg-gray-600 text-white px-8 py-3 rounded-lg hover:bg-gray-700 font-medium' %>
    </div>
    
  <% else %>
    <!-- Estado Vacío -->
    <div class="bg-white rounded-2xl shadow-sm border p-12 text-center">
      <div class="max-w-md mx-auto">
        <div class="text-6xl mb-4"></div>
        <h3 class="text-xl font-semibold text-gray-800 mb-2">
          <% if params[:filtro].present? %>
            No tienes <%= current_user.doctor? ? 'citas' : 'reservas' %> <%= case params[:filtro]
                                  when 'proximas' then 'próximas'
                                  when 'pasadas' then 'pasadas' 
                                  when 'pendientes' then 'pendientes'
                                  when 'confirmadas' then 'confirmadas'
                                  end %>
          <% else %>
            No tienes <%= current_user.doctor? ? 'citas programadas' : 'reservas médicas programadas' %>
          <% end %>
        </h3>
        <p class="text-gray-600 mb-6">Cuando tengas reservas, aparecerán listadas aquí.</p>
        <div class="flex justify-center space-x-4">
          <%= link_to 'Volver al Inicio', root_path, class: 'bg-gray-600 text-white px-6 py-3 rounded-lg hover:bg-gray-700 font-medium' %>
          <%= link_to 'Recargar', reservas_path, class: 'bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 font-medium' %>
        </div>
      </div>
    </div>
  <% end %>
</div>