<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="bg-white rounded-2xl shadow-sm border p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Agendar Nueva Cita</h1>
      <%= link_to 'Volver', reservas_path, class: 'bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 font-medium' %>
    </div>

    <%= form_with(model: @reserva, local: true) do |form| %>
      <%= form.hidden_field :doctor_id, value: @doctor.id %>
      
      <!-- Información fija del doctor -->
      <div class="bg-blue-50 rounded-lg p-4 mb-6">
        <h3 class="text-lg font-semibold text-blue-800 mb-3">Información del Médico</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-blue-700 mb-1">Médico:</label>
            <p class="text-lg font-semibold text-gray-900"><%= @doctor.nombre_completo %></p>
          </div>
          <div>
            <label class="block text-sm font-medium text-blue-700 mb-1">Ubicación:</label>
            <p class="text-lg font-semibold text-gray-900">
              <% if @horarios_disponibles.first&.ubicacion.present? %>
                <%= @horarios_disponibles.first.ubicacion %>
              <% else %>
                Consultorio principal
              <% end %>
            </p>
          </div>
        </div>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-2">Motivo de la consulta:</label>
        <%= form.text_area :motivo, rows: 3, placeholder: 'Describe el motivo de tu consulta...', class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500', required: true %>
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-4">Selecciona fecha y hora:</label>
        
        <% if @horarios_disponibles.any? %>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 max-h-96 overflow-y-auto">
            <% @horarios_disponibles.group_by(&:dia_semana).each do |dia, horarios| %>
              <div class="bg-gray-50 rounded-lg p-4">
                <%# Calcular la fecha CORRECTA para el próximo día de la semana %>
                <% fecha_real = Date.today.next_week.beginning_of_week + dia.to_i.days %>
                <h3 class="font-semibold text-gray-800 mb-3">
                  <%= dia.humanize %> - <%= l(fecha_real, format: :short) %>
                </h3>
                <div class="space-y-2">
                  <% horarios.each do |horario| %>
                    <label class="block cursor-pointer p-3 rounded border border-gray-200 hover:border-blue-300 hover:bg-blue-50 transition-colors">
                      <div class="flex items-center">
                        <%= form.radio_button :fecha_hora, 
                              "#{fecha_real} #{horario.hora_inicio.strftime('%H:%M')}", 
                              class: 'text-blue-600 focus:ring-blue-500 mr-3',
                              required: true,
                              data: { 
                                duracion: horario.duracion_cita,
                                ubicacion: horario.ubicacion 
                              } %>
                        <div class="flex-1">
                          <div class="font-medium text-gray-900">
                            <%= horario.hora_inicio.strftime('%H:%M') %> - <%= horario.hora_fin.strftime('%H:%M') %>
                          </div>
                          <div class="text-sm text-gray-600 mt-1">
                            Duración: <strong><%= horario.duracion_cita %> minutos</strong>
                          </div>
                        </div>
                      </div>
                    </label>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-4 text-center">
            <p class="text-yellow-700">Este médico no tiene horarios disponibles actualmente.</p>
            <%= link_to 'Buscar otro médico', horarios_path, class: 'bg-yellow-600 text-white px-4 py-2 rounded-lg hover:bg-yellow-700 font-medium mt-2 inline-block' %>
          </div>
        <% end %>
      </div>

      <!-- Campos ocultos para duración y ubicación -->
      <%= form.hidden_field :duracion, id: 'duracion-field', value: @horarios_disponibles.first&.duracion_cita || 30 %>
      <%= form.hidden_field :ubicacion, id: 'ubicacion-field', value: @horarios_disponibles.first&.ubicacion || "Consultorio del doctor" %>

      <div class="flex justify-end space-x-3">
        <%= link_to 'Cancelar', reservas_path, class: 'bg-gray-300 text-gray-700 px-6 py-3 rounded-lg hover:bg-gray-400 font-medium' %>
        <% if @horarios_disponibles.any? %>
          <%= form.submit 'Agendar Cita', class: 'bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 font-medium cursor-pointer' %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>