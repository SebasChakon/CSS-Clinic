<div class="bg-white rounded-2xl shadow-sm border p-6 mb-8">
  <div class="flex justify-between items-center mb-4">
    <h3 class="text-lg font-semibold text-gray-800">Farmacias Cercanas</h3>
    <%= button_to "Buscar cerca de mí", 
                  farmacias_cercanas_reservas_path, 
                  method: :get,
                  class: 'bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 text-sm font-medium',
                  data: { turbo_frame: "farmacias-frame" } %>
  </div>
  
  <%= turbo_frame_tag "farmacias-frame" do %>
    <% if @farmacias && @farmacias.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @farmacias.each do |farmacia| %>
          <div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow bg-white">
            <h4 class="font-semibold text-gray-900 text-base mb-2"><%= farmacia[:nombre] %></h4>
            <p class="text-sm text-gray-600 mb-3"><%= farmacia[:direccion].split(',').first(3).join(', ') %></p>
            <div class="flex justify-end">
              <a href="https://www.openstreetmap.org/?mlat=<%= farmacia[:latitud] %>&mlon=<%= farmacia[:longitud] %>#map=17/<%= farmacia[:latitud] %>/<%= farmacia[:longitud] %>" 
                 target="_blank" 
                 rel="noopener noreferrer"
                 class="text-blue-600 hover:text-blue-800 text-sm font-medium flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"></path>
                </svg>
                Ver en mapa
              </a>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-4">
        <p class="text-gray-600">No se encontraron farmacias cercanas.</p>
        <p class="text-sm text-gray-500 mt-1">Usando ubicación por defecto (Santiago)</p>
      </div>
    <% end %>
  <% end %>
</div>