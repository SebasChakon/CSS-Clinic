<div class="container mx-auto px-4 py-8">
  <div class="bg-white shadow-md rounded-lg p-6">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Editar Reserva</h1>

    <%= form_with(model: @reserva, local: true) do |form| %>
      <div class="mb-4">
        <%= form.label :motivo, 'Motivo de la consulta', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= form.text_area :motivo, rows: 4, 
              class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500',
              placeholder: 'Describe el motivo de tu consulta...' %>
      </div>

      <div class="mb-4">
        <%= form.label :notas, 'Notas adicionales', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= form.text_area :notas, rows: 3, 
              class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500',
              placeholder: 'Cualquier información adicional que quieras compartir...' %>
      </div>

      <div class="flex justify-end space-x-3">
        <%= link_to 'Cancelar', reserva_path(@reserva), class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400' %>
        <%= form.submit 'Actualizar Reserva', class: 'bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>