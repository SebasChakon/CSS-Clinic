<div class="container mx-auto px-4 py-8">
  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Editar Notas de la Cita</h1>
      <%= link_to 'Volver', reserva_path(@reserva), class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400' %>
    </div>

    <!-- Mostrar alerta si está cancelada -->
    <% if @reserva.cancelada? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
        <p class="text-red-700 font-medium">No se pueden editar notas de una cita cancelada.</p>
      </div>
    <% end %>

    <%= form_with(model: @reserva, local: true) do |form| %>
      <% if @reserva.errors.any? %>
        <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mb-6">
          <h2><%= pluralize(@reserva.errors.count, "error") %> prohibieron guardar las notas:</h2>
          <ul>
            <% @reserva.errors.each do |error| %>
              <li><%= error.full_message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- Información de la cita (solo lectura) -->
      <div class="mb-6 p-4 bg-gray-50 rounded-lg">
        <h3 class="text-lg font-semibold text-gray-700 mb-2">Información de la Cita</h3>
        <p><strong>Paciente:</strong> <%= @reserva.paciente.nombre_completo %></p>
        <p><strong>Fecha:</strong> <%= l(@reserva.fecha_hora, format: :long) %></p>
        <p><strong>Motivo:</strong> <%= @reserva.motivo %></p>
        <p><strong>Estado:</strong> 
          <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= estado_badge_class(@reserva.estado) %>">
            <%= @reserva.estado.humanize %>
          </span>
        </p>
      </div>

      <!-- Solo notas editables para doctores, deshabilitado si cancelada -->
      <div class="mb-4">
        <%= form.label :notas, 'Notas médicas', class: 'block text-sm font-medium text-gray-700 mb-2' %>
        <%= form.text_area :notas, 
              rows: 6, 
              disabled: @reserva.cancelada?,
              class: "w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 #{@reserva.cancelada? ? 'bg-gray-100 cursor-not-allowed' : ''}",
              placeholder: @reserva.cancelada? ? 'No se pueden editar notas de citas canceladas' : 'Agregar notas médicas, observaciones, recomendaciones...' %>
        <p class="text-sm text-gray-500 mt-1">
          <% if @reserva.cancelada? %>
            Las citas canceladas no pueden ser editadas.
          <% else %>
            Solo los médicos pueden editar estas notas.
          <% end %>
        </p>
      </div>

      <div class="flex justify-end space-x-3">
        <%= link_to 'Cancelar', reserva_path(@reserva), class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400' %>
        <% unless @reserva.cancelada? %>
          <%= form.submit 'Actualizar Notas', class: 'bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700 cursor-pointer' %>
        <% end %>
      </div>
    <% end %>
  </div>
</div>