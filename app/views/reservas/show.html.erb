<div class="container mx-auto px-4 py-8">
  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">
        <%= current_user.doctor? ? 'Detalle de Cita' : 'Detalle de Reserva' %>
      </h1>
      <div class="flex space-x-2">
        <%= link_to 'Volver a la lista', reservas_path, class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400' %>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <!-- Información del Paciente/Doctor -->
      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-4">
          <%= current_user.doctor? ? 'Información del Paciente' : 'Información del Médico' %>
        </h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500">Nombre:</label>
            <p class="mt-1 text-sm text-gray-900">
              <%= current_user.doctor? ? @reserva.paciente.nombre_completo : @reserva.doctor.nombre_completo %>
            </p>
          </div>
          
          <% if current_user.doctor? && @reserva.paciente.phone.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-500">Teléfono:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.paciente.phone %></p>
          </div>
          <% end %>
          
          <% if current_user.doctor? && @reserva.paciente.email.present? %>
          <div>
            <label class="block text-sm font-medium text-gray-500">Email:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.paciente.email %></p>
          </div>
          <% end %>
        </div>
      </div>

      <!-- Información de la Cita -->
      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Información de la Cita</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500">Fecha y Hora:</label>
            <p class="mt-1 text-sm text-gray-900">
              <% fecha = @reserva.fecha_hora.to_date %>
              <%= case fecha.wday
                  when 0 then 'Domingo'
                  when 1 then 'Lunes' 
                  when 2 then 'Martes'
                  when 3 then 'Miércoles'
                  when 4 then 'Jueves'
                  when 5 then 'Viernes'
                  when 6 then 'Sábado'
                  end %>,
              <%= fecha.strftime('%d de ') %><%= case fecha.month
                  when 1 then 'enero'
                  when 2 then 'febrero'
                  when 3 then 'marzo'
                  when 4 then 'abril'
                  when 5 then 'mayo'
                  when 6 then 'junio'
                  when 7 then 'julio'
                  when 8 then 'agosto'
                  when 9 then 'septiembre'
                  when 10 then 'octubre'
                  when 11 then 'noviembre'
                  when 12 then 'diciembre'
                  end %><%= fecha.strftime(' de %Y') %> a las 
              <%= @reserva.fecha_hora.strftime('%H:%M') %>
            </p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-500">Estado:</label>
            <span class="mt-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= estado_badge_class(@reserva.estado) %>">
              <%= @reserva.estado.humanize %>
            </span>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-500">Duración Estimada:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.duracion %> minutos</p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-500">Ubicación:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.ubicacion %></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Motivo y Notas -->
    <div class="mt-6 pt-6 border-t border-gray-200">
      <div class="grid grid-cols-1 gap-6">
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-2">Motivo de la consulta:</label>
          <p class="text-sm text-gray-900 bg-gray-50 p-3 rounded border"><%= @reserva.motivo %></p>
        </div>
        
        <% if @reserva.notas.present? %>
        <div>
          <label class="block text-sm font-medium text-gray-500 mb-2">Notas médicas:</label>
          <p class="text-sm text-gray-900 bg-gray-50 p-3 rounded border"><%= @reserva.notas %></p>
        </div>
        <% end %>
      </div>
    </div>

    <!-- Bloque de reseñas -->
    <div class="mt-6 pt-6 border-t border-gray-200">
      <h3 class="text-lg font-semibold mb-3">Reseñas</h3>

      <div class="mb-4">
        <strong>Promedio:</strong>
        <span class="ml-2 text-xl"><%= @reserva.average_rating %> / 5</span>
        <span class="text-sm text-gray-500">(<%= @reserva.resenas.count %> reseñas)</span>
      </div>

      <% if @reserva.resenas.any? %>
        <div class="space-y-3">
          <%= render partial: 'resenas/resena', collection: @reserva.resenas.order(created_at: :desc), as: :resena %>
        </div>
      <% else %>
        <p class="text-gray-500">Aún no hay reseñas para esta cita.</p>
      <% end %>

      <%# Botón para crear reseña: solo paciente y sólo si la cita ya pasó o está completada y no tiene reseña %>
      <% if @reserva.paciente_id == current_user.id && @reserva.completada? && !@reserva.resenas.exists?(autor: current_user) %>
        <div class="mt-4">
          <%= link_to 'Dejar Reseña', new_reserva_resena_path(@reserva), class: 'bg-green-600 text-white px-4 py-2 rounded' %>
        </div>
      <% end %>
    </div>




    <!-- Acciones -->
    <div class="mt-8 pt-6 border-t border-gray-200 flex space-x-4">
      <% if current_user.doctor? %>
        <!-- SOLO DOCTORES pueden confirmar, completar y editar notas -->
        <% if @reserva.pendiente? %>
          <%= link_to 'Confirmar Cita', confirmar_reserva_path(@reserva), 
              class: 'bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700' %>
        <% end %>
        
        <% if @reserva.confirmada? %>
          <%= link_to 'Marcar como Completada', completar_reserva_path(@reserva), 
              class: 'bg-purple-600 text-white px-4 py-2 rounded hover:bg-purple-700' %>
        <% end %>
        
        <!-- SOLO mostrar editar si NO está cancelada -->
        <% unless @reserva.cancelada? %>
          <%= link_to 'Editar Notas', edit_reserva_path(@reserva), class: 'bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700' %>
        <% end %>
        
        <% if @reserva.pendiente? || @reserva.confirmada? %>
          <%= link_to 'Cancelar', cancelar_reserva_path(@reserva), 
              data: { confirm: '¿Estás seguro de cancelar esta cita?' },
              class: 'bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700' %>
        <% end %>
        
      <% else %>
        <!-- PACIENTES solo pueden cancelar (NO editar) -->
        <% if @reserva.pendiente? || @reserva.confirmada? %>
          <%= link_to 'Cancelar', cancelar_reserva_path(@reserva), 
              data: { confirm: '¿Estás seguro de cancelar esta reserva?' },
              class: 'bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700' %>
        <% end %>
      <% end %>
    </div>
  </div>
</div>