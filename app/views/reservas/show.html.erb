<div class="container mx-auto px-4 py-8">
  <div class="bg-white shadow-md rounded-lg p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Detalle de Reserva</h1>
      <%= link_to 'Volver a mis reservas', reservas_path, class: 'text-blue-600 hover:text-blue-800' %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Información de la Cita</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500">Médico:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.doctor.nombre_completo %></p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-500">Fecha y Hora:</label>
            <p class="mt-1 text-sm text-gray-900"><%= l(@reserva.fecha_hora, format: :long) %></p>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-500">Estado:</label>
            <span class="mt-1 px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= estado_badge_class(@reserva.estado) %>">
              <%= @reserva.estado.humanize %>
            </span>
          </div>
        </div>
      </div>

      <div>
        <h2 class="text-lg font-semibold text-gray-700 mb-4">Detalles de la Consulta</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-500">Motivo de la consulta:</label>
            <p class="mt-1 text-sm text-gray-900"><%= @reserva.motivo %></p>
          </div>
          
          <% if @reserva.notas.present? %>
            <div>
              <label class="block text-sm font-medium text-gray-500">Notas adicionales:</label>
              <p class="mt-1 text-sm text-gray-900"><%= @reserva.notas %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>

    <% if @reserva.pendiente? || @reserva.confirmada? %>
      <div class="mt-8 pt-6 border-t border-gray-200 flex space-x-4">
        <%= link_to 'Editar Reserva', edit_reserva_path(@reserva), class: 'bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700' %>
        <%= link_to 'Cancelar Reserva', cancelar_reserva_path(@reserva), 
            method: :patch, 
            data: { confirm: '¿Estás seguro de cancelar esta reserva?' },
            class: 'bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700' %>
      </div>
    <% end %>
  </div>
</div>