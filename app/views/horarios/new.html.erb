<div class="container mx-auto px-4 py-8 max-w-2xl">
  <div class="bg-white rounded-2xl shadow-sm border p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Agregar Nuevo Horario</h1>
      <%= link_to 'Volver', horarios_path, class: 'bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 font-medium' %>
    </div>

    <%= form_with(model: @horario, url: horarios_path, local: true) do |form| %>
      <div class="space-y-4">
        <div>
          <%= form.label :dia_semana, 'Día de la semana', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= form.select :dia_semana, HorarioAtencion.dias_semana_options, {}, 
                        class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500' %>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <%= form.label :hora_inicio, 'Hora de inicio', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= form.time_field :hora_inicio, class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500', required: true %>
          </div>

          <div>
            <%= form.label :hora_fin, 'Hora de fin', class: 'block text-sm font-medium text-gray-700 mb-1' %>
            <%= form.time_field :hora_fin, class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500', required: true %>
            <p class="text-sm text-gray-500 mt-1">Duración mínima: 15 minutos</p>
          </div>
        </div>

        <div>
          <%= form.label :ubicacion, 'Ubicación', class: 'block text-sm font-medium text-gray-700 mb-1' %>
          <%= form.text_field :ubicacion, placeholder: 'Ej: Consultorio 201, Piso 2', class: 'w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500', required: true %>
        </div>
      </div>

      <div class="flex justify-end space-x-3 mt-6">
        <%= link_to 'Cancelar', horarios_path, class: 'bg-gray-300 text-gray-700 px-4 py-2 rounded-lg hover:bg-gray-400' %>
        <%= form.submit 'Agregar Horario', class: 'bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 font-medium cursor-pointer' %>
      </div>
    <% end %>
  </div>
</div>