<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="bg-white rounded-2xl shadow-sm border p-6">
    <div class="flex justify-between items-center mb-6">
      <div class="flex items-center space-x-4">
        <%= link_to '← Volver', root_path, class: 'bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 font-medium' %>
        <h1 class="text-2xl font-bold text-gray-900">Mis Horarios de Atención</h1>
      </div>
      <%= link_to 'Agregar Horario', new_horario_path, class: 'bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 font-medium' %>
    </div>

    <% if @horarios.any? %>
      <div class="space-y-6">
        <% @horarios.group_by(&:fecha).each do |fecha, horarios_dia| %>
          <div class="border rounded-lg">
            <div class="bg-gray-100 px-4 py-3 border-b">
              <h3 class="font-semibold text-gray-800">
                <%= case fecha.wday
                    when 0 then 'Domingo'
                    when 1 then 'Lunes' 
                    when 2 then 'Martes'
                    when 3 then 'Miércoles'
                    when 4 then 'Jueves'
                    when 5 then 'Viernes'
                    when 6 then 'Sábado'
                    end %> - 
                <%= fecha.strftime('%d de ') %><%= case fecha.month
                    when 1 then 'enero'
                    when 2 then 'febrero'
                    when 3 then 'marzo'
                    when 4 then 'abril'
                    when 5 then 'mayo'
                    when 6 then 'junio'
                    when 7 then 'julio'
                    when 8 then 'agosto'
                    when 9 then 'septiembre'
                    when 10 then 'octubre'
                    when 11 then 'noviembre'
                    when 12 then 'diciembre'
                    end %><%= fecha.strftime(' de %Y') %>
              </h3>
            </div>
            
            <div class="p-4">
              <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                <% horarios_dia.each do |horario| %>
                  <div class="flex justify-between items-center bg-white border rounded-lg p-3">
                    <div>
                      <p class="font-medium text-gray-800">
                        <%= horario.hora_inicio.strftime('%H:%M') %> - <%= horario.hora_fin.strftime('%H:%M') %>
                      </p>
                      <p class="text-sm text-gray-600">
                        Duración: <strong><%= horario.duracion_cita %> minutos</strong>
                      </p>
                      <p class="text-sm text-gray-600">
                        Ubicación: <strong><%= horario.ubicacion %></strong>
                      </p>
                      <span class="text-sm <%= horario.disponible ? 'text-green-600' : 'text-red-600' %>">
                        <%= horario.disponible ? 'Disponible' : 'Ocupado' %>
                      </span>
                    </div>
                    <div class="flex space-x-2">
                      <%= link_to 'Editar', edit_horario_path(horario), class: 'text-blue-600 hover:text-blue-800 text-sm' %>
                      <%= button_to 'Eliminar', horario_path(horario), 
                          method: :delete,
                          form: { data: { turbo_confirm: '¿Estás seguro de eliminar este horario?' } },
                          class: 'text-red-600 hover:text-red-800 text-sm bg-transparent border-none p-0' %>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500">No has agregado horarios de atención aún.</p>
        <p class="text-gray-400 text-sm mt-2">Haz click en "Agregar Horario" para comenzar.</p>
      </div>
    <% end %>
  </div>
</div>