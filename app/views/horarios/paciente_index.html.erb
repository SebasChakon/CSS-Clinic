<div class="container mx-auto px-4 py-8">
  <div class="bg-white rounded-2xl shadow-sm border p-6">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold text-gray-900">Médicos Disponibles</h1>
      <%= link_to 'Volver al Inicio', root_path, class: 'bg-gray-600 text-white px-4 py-2 rounded-lg hover:bg-gray-700 font-medium' %>
    </div>

    <% if @doctores.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @doctores.each do |doctor| %>
          <div class="bg-white border rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="text-center mb-4">
              <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-3">
                <span class="text-2xl"> </span>
              </div>
              <h3 class="text-lg font-semibold text-gray-800"><%= doctor.nombre_completo %></h3>
              <p class="text-gray-600 text-sm">Médico</p>
            </div>
            
            <div class="text-center">
              <%= link_to 'Agendar Cita', new_reserva_path(doctor_id: doctor.id), 
                  class: 'bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 font-medium w-full' %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500">No hay médicos disponibles en este momento.</p>
      </div>
    <% end %>
  </div>
</div>