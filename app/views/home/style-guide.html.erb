<div class="min-h-screen bg-gray-100 py-10 px-4">
  <div class="max-w-6xl mx-auto space-y-10">

    <!-- Título principal -->
    <div class="bg-white shadow-md rounded-lg p-8 text-center">
      <h1 class="text-4xl font-bold text-gray-800 mb-2">Guía de Estilos - MediConnect</h1>
      <p class="text-gray-600">Componentes base reutilizables en todas las vistas</p>
    </div>

    <!-- Tipografía -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Tipografía</h2>
      <div class="space-y-3 text-gray-800">
        <p class="text-3xl font-bold">Título grande (text-3xl font-bold)</p>
        <p class="text-2xl font-semibold">Subtítulo (text-2xl font-semibold)</p>
        <p class="text-lg font-medium">Texto destacado (text-lg font-medium)</p>
        <p class="text-base">Texto normal (text-base)</p>
        <p class="text-sm text-gray-600">Texto pequeño y gris (text-sm text-gray-600)</p>
      </div>
    </section>

    <!-- Botones -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Botones</h2>
      <div class="flex flex-wrap gap-4">
        <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Primario</button>
        <button class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700">Éxito</button>
        <button class="bg-red-600 text-white px-4 py-2 rounded hover:bg-red-700">Peligro</button>
        <button class="bg-gray-600 text-white px-4 py-2 rounded hover:bg-gray-700">Secundario</button>
        <button class="border border-blue-600 text-blue-600 px-4 py-2 rounded hover:bg-blue-50">Transparente</button>
      </div>
    </section>

    <!-- Tarjetas -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Tarjetas</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white border border-gray-200 shadow-sm rounded-lg p-4 hover:shadow-md transition-shadow">
          <h3 class="text-xl font-semibold text-gray-800 mb-2">Tarjeta estándar</h3>
          <p class="text-gray-600">Usa padding (p-4) y sombra ligera.</p>
        </div>
        <div class="bg-blue-50 border border-blue-100 rounded-lg p-4">
          <h3 class="text-xl font-semibold text-blue-800 mb-2">Tarjeta informativa</h3>
          <p class="text-blue-700">Ideal para secciones de datos o detalles de reserva.</p>
        </div>
        <div class="bg-green-50 border border-green-100 rounded-lg p-4">
          <h3 class="text-xl font-semibold text-green-800 mb-2">Tarjeta de éxito</h3>
          <p class="text-green-700">Perfecta para mensajes de confirmación.</p>
        </div>
      </div>
    </section>

    <!-- Formularios -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Campos de Formulario</h2>
      <form class="space-y-4">
        <div>
          <label class="block text-sm font-medium text-blue-700 mb-1">Nombre</label>
          <input type="text" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2" placeholder="Ingresa tu nombre">
        </div>
        <div>
          <label class="block text-sm font-medium text-blue-700 mb-1">Correo Electrónico</label>
          <input type="email" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2" placeholder="correo@ejemplo.com">
        </div>
        <div>
          <label class="block text-sm font-medium text-blue-700 mb-1">Mensaje</label>
          <textarea rows="3" class="w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 px-3 py-2" placeholder="Escribe un mensaje..."></textarea>
        </div>
        <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">Enviar</button>
      </form>
    </section>

    <!-- Badges -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Badges / Estados</h2>
      <div class="flex flex-wrap gap-3">
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-green-100 text-green-800">Confirmada</span>
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-yellow-100 text-yellow-800">Pendiente</span>
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-red-100 text-red-800">Cancelada</span>
        <span class="px-3 py-1 text-sm font-semibold rounded-full bg-blue-100 text-blue-800">En curso</span>
      </div>
    </section>

    <!-- Alertas -->
    <section class="bg-white shadow-md rounded-lg p-6">
      <h2 class="text-2xl font-semibold text-blue-700 mb-4">Alertas</h2>
      <div class="space-y-3">
        <div class="bg-green-50 border border-green-200 rounded-lg p-3 text-green-800">
          ✅ Operación realizada con éxito.
        </div>
        <div class="bg-yellow-50 border border-yellow-200 rounded-lg p-3 text-yellow-800">
          ⚠️ Revisa los datos ingresados.
        </div>
        <div class="bg-red-50 border border-red-200 rounded-lg p-3 text-red-800">
          ❌ Error al procesar la solicitud.
        </div>
      </div>
    </section>

  </div>
</div>