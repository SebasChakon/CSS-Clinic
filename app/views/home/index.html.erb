<div class="min-h-screen bg-gray-100 py-10 px-4">
  <div class="max-w-6xl mx-auto">
    <div class="bg-gray-50 shadow-md rounded-lg p-6 mb-10 text-center">
      <h1 class="text-3xl font-bold text-gray-800 mb-2">Bienvenido a CSS Clinic!</h1>
      <p class="text-gray-600 text-base mb-4">
        Tu plataforma para gestionar reservas médicas, comunicarte con profesionales y acceder a tus citas fácilmente.
      </p>
      <%= image_tag "Logo.png", alt: "Logo de la aplicación", class: "w-28 h-28 mx-auto mb-4 rounded-lg" %>

      <%= button_to "Cerrar Sesión", destroy_user_session_path, method: :delete,
          class: "bg-red-600 text-white px-5 py-2 rounded-lg hover:bg-red-700 transition-colors" %>
    </div>

    <div class="bg-gray-50 shadow-md rounded-lg p-8 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="p-6 hover:shadow-lg transition-all duration-200 rounded-lg border border-gray-200">
        <h2 class="text-2xl font-semibold text-blue-700 mb-3">Mis Reservas</h2>
        <p class="text-gray-600 mb-6">
          Revisa tus citas médicas y accede a los detalles o chat con tu doctor.
        </p>
        <%= link_to 'Ver Reservas', reservas_path, class: 'inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors' %>
      </div>

      <div class="p-6 hover:shadow-lg transition-all duration-200 rounded-lg border border-gray-200">
        <h2 class="text-2xl font-semibold text-blue-700 mb-3">Mi Perfil</h2>
        <p class="text-gray-600 mb-6">
          Actualiza tus datos personales, información médica y preferencias.
        </p>
        <%= link_to 'Ver Perfil', edit_user_registration_path, class: 'inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors' %>
      </div>
    </div>

    <!-- Solo para pacientes, buscar médicos y farmacias -->
    <% if current_user.paciente? %>
    <div class="bg-gray-50 shadow-md rounded-lg p-8 mt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="p-6 hover:shadow-lg transition-all duration-200 rounded-lg border border-gray-200">
        <h2 class="text-2xl font-semibold text-blue-700 mb-3">Agendar Nueva Cita</h2>
        <p class="text-gray-600 mb-6">
          Encuentra médicos disponibles y agenda tu próxima cita médica.
        </p>
        <%= link_to 'Buscar Médicos', horarios_path, class: 'inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors' %>
      </div>

      <div class="p-6 hover:shadow-lg transition-all duration-200 rounded-lg border border-gray-200">
        <h2 class="text-2xl font-semibold text-blue-700 mb-3">Farmacias Cercanas</h2>

        <% if session[:ultima_ubicacion] && @farmacias %>
          <p class="text-gray-600 mb-2">Mostrando farmacias cerca de tu ubicación actual</p>
          <p class="text-xs text-blue-600 mb-4">
            Ubicación detectada: 
          </p>

          <% if @farmacias.any? %>
            <div class="space-y-3 mb-4">
              <% @farmacias.first(3).each do |farmacia| %>
                <div class="flex justify-between items-center p-3 bg-gray-50 rounded-lg border">
                  <div class="flex-1">
                    <p class="font-medium text-gray-900 text-sm">
                      <%= farmacia['nombre'] || farmacia[:nombre] %>
                    </p>
                    <p class="text-xs text-gray-600 line-clamp-2">
                      <%= farmacia['direccion'] || farmacia[:direccion] %>
                    </p>
                  </div>
                  <a href="https://www.openstreetmap.org/?mlat=<%= farmacia['latitud'] %>&mlon=<%= farmacia['longitud'] %>#map=17/<%= farmacia['latitud'] %>/<%= farmacia['longitud'] %>" 
                    target="_blank" 
                    class="text-blue-600 hover:text-blue-800 text-xs font-medium ml-2 whitespace-nowrap bg-blue-50 px-2 py-1 rounded">
                    Ver mapa
                  </a>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-4">
              <p class="text-gray-500 text-sm mb-2">No se encontraron farmacias cercanas a tu ubicación.</p>
            </div>
          <% end %>

        <% else %>
          <!-- Estado inicial -->
          <p class="text-gray-600 mb-4">Haz clic en el botón para encontrar farmacias cerca de tu ubicación actual</p>
          <div class="text-center py-6">
            <p class="text-gray-600 text-sm">Presiona el botón para detectar farmacias cercanas</p>
          </div>
        <% end %>

        <div class="flex space-x-2">
          <button 
            data-controller="geolocation"
            data-action="click->geolocation#getLocation"
            data-geolocation-target="button"
            class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 text-sm font-medium flex-1 text-center"
          >
            <span></span> Usar mi ubicación real
          </button>
          
          <% if session[:ultima_ubicacion] %>
            <%= link_to "Actualizar", 
                        farmacias_cercanas_reservas_path, 
                        class: 'bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 text-sm font-medium flex-1 text-center' %>
          <% else %>
            <%= link_to "Recargar", 
                        root_path, 
                        class: 'bg-purple-600 text-white px-4 py-2 rounded-lg hover:bg-purple-700 text-sm font-medium flex-1 text-center' %>
          <% end %>
        </div>

        <p class="text-xs text-gray-600 mt-2 text-center">
          <% if session[:ultima_ubicacion] %>
            Mostrando farmacias cerca de tu ubicación real
          <% else %>
            Tu ubicación se usará solo para encontrar farmacias cercanas
          <% end %>
        </p>
      </div>
    </div>
    <% end %>

    <!-- Solo para doctores, gestión de horarios -->
    <% if current_user.doctor? %>
    <div class="bg-gray-50 shadow-md rounded-lg p-8 mt-8 text-center">
      <h2 class="text-2xl font-semibold text-blue-700 mb-3">Gestión Médica</h2>
      <p class="text-gray-600 mb-6">
        Gestiona tus horarios de atención y citas con pacientes.
      </p>
      <%= link_to 'Gestionar Horarios', horarios_path, class: 'inline-block bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700 transition-colors' %>
    </div>
    <% end %>
  </div>
</div>